{% extends "base.njk" %}

{% block titulo %}Nueva Formación - Clash of Clans{% endblock %}

{% block contenido %}
<div class="max-w-6xl mx-auto p-4 animate-coc-fade-in">
  
  <!-- HEADER CON LOS CONTADORES DE CAPACIDAD DE TROPAS Y HECHIZOS -->
  <header class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b-4 border-coc-wood-light pb-4">
    <div>
      <h1 class="text-3xl font-black text-coc-wood-light uppercase tracking-wide">Crear Nueva Formación</h1>
      <p class="text-sm text-gray-600 font-medium">Diseña tu ejército estratégico combinando tropas y hechizos.</p>
    </div>
    <div class="flex gap-4">
      <div class="bg-linear-to-b from-coc-wood-light to-coc-wood-dark border-2 border-coc-gold px-4 py-2 rounded-lg text-center shadow-md">
        <span class="block text-xs uppercase text-coc-text-muted font-bold">Capacidad Tropas</span>
        <span class="text-xl font-black text-coc-text-gold">0 / 352</span>
      </div>
      <div class="bg-linear-to-b from-coc-wood-light to-coc-wood-dark border-2 border-coc-gold px-4 py-2 rounded-lg text-center shadow-md">
        <span class="block text-xs uppercase text-coc-text-muted font-bold">Capacidad Hechizos</span>
        <span class="text-xl font-black text-white">0 / 11</span>
      </div>
    </div>
  </header>

  <!-- FORMULARIO INSERTAR FORMACIÓN -->
  <form action="/formaciones/insertar" method="POST" class="space-y-8">
    
    <!-- SECCIÓN DE NOMBRE Y DESCRIPCIÓN DE LA FORMACIÓN -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 bg-linear-to-b from-coc-wood-light to-coc-wood-dark border-2 border-coc-gold p-6 rounded-xl shadow-xs">
      <div class="md:col-span-1">
        <label for="nombre" class="block text-sm font-black text-coc-text-muted uppercase tracking-wider mb-2">Nombre del Ejército</label>
        <input type="text" id="nombre" name="nombre" placeholder="Ej: Ataque Híbrido TH15" required
               class="w-full px-4 py-2.5 bg-white border-2 border-coc-wood-light rounded-lg font-medium text-coc-wood-dark focus:outline-hidden focus:border-coc-gold">
      </div>
      <div class="md:col-span-2">
        <label for="descripcion" class="block text-sm font-black text-coc-text-muted uppercase tracking-wider mb-2">Estrategia / Descripción</label>
        <input type="text" id="descripcion" name="descripcion" placeholder="Explica brevemente cómo usar esta formación en batalla..." required
               class="w-full px-4 py-2.5 bg-white border-2 border-coc-wood-light rounded-lg font-medium text-coc-wood-dark focus:outline-hidden focus:border-coc-gold">
      </div>
    </div>


    <!-- SECCIÓN DE TROPAS Y HECHIZOS SELECCIONADOS PARA LA FORMACIÓN -->
    <section class="bg-linear-to-b from-coc-wood-light to-coc-wood-dark p-6 rounded-2xl border-2 border-dashed border-coc-wood-light">
      <h2 class="text-xl font-black text-coc-text-light uppercase tracking-wider mb-4 flex items-center gap-2">
        Composición Actual de la Formación
      </h2>
      <div class="flex flex-wrap gap-4">
        <!-- Implementaré la logica mas adelante para mostrar las tropas y hechizos seleccionados -->
        <p class="text-sm font-bold text-gray-500 italic">No hay ninguna tropa o hechizo seleccionado..</p>
    </section>


    <!-- SECCIÓN DE TROPAS DISPONIBLES -->
    <section>
      <h2 class="text-xl font-black text-coc-wood-dark uppercase tracking-wider mb-4 flex items-center gap-2">
        Seleccionar Tropas Disponibles
      </h2>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {% for tropa in tropas %}
          <div class="relative aspect-square bg-sky-300 border-[3px]  rounded-xl shadow-lg hover:border-coc-gold">
            
            <img src="{{ tropa.imagenIcono }}" alt="{{ tropa.nombre }}" class="w-full h-full object-cover select-none">
            
            <a href="/tropas/{{ tropa.id }}" target="_blank" 
               class="absolute top-1.5 right-1.5 w-6 h-6 bg-sky-500 border border-black rounded-md flex items-center justify-center font-bold text-white shadow-xs hover:bg-sky-600"
               title="Ver info de {{ tropa.nombre }}">
              i
            </a>
            
            <div class="absolute top-[40%] left-1.5 w-7 h-7 bg-zinc-800 border-2 border-zinc-600 rounded-md flex items-center justify-center font-black text-xs text-white shadow-md">
              10
            </div>
            
            <div class="absolute bottom-0 left-0 w-full bg-black/40 border-t border-white/20 px-2 py-1 flex items-center justify-between text-white font-black text-sm">
              <span>{{ tropa.espacio }}</span>
              <div class="w-5 h-5 bg-zinc-700 flex items-center justify-center overflow-hidden">
                <img src="/img/decorativas" alt="Icono de tropa">
              </div>
            </div>
          </div>
        {% else %}
          <p class="col-span-full text-sm font-bold text-gray-500 italic">No hay tropas actualmente.</p>
        {% endfor %}
      </div>
    </section>


    <!-- SECCIÓN DE HECHIZOS DISPONIBLES -->
    <section>
      <h2 class="text-xl font-black text-coc-wood-dark uppercase tracking-wider mb-4 flex items-center gap-2">
        Seleccionar Hechizos Disponibles
      </h2>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {% for hechizo in hechizos %}
          <div class="relative aspect-square bg-emerald-500 border-[3px] rounded-4xl shadow-lg overflow-hidden group hover:border-coc-gold transition-all duration-150">
            
            <img src="{{ hechizo.imagenIcono }}" alt="{{ hechizo.nombre }}" class="w-full h-full object-cover select-none">
            
            <a href="/hechizos/{{ hechizo.id }}" target="_blank" 
               class="absolute top-3.5 right-2.5 w-6 h-6 bg-sky-500 border border-black rounded-md flex items-center justify-center font-bold text-sm text-white shadow-xs hover:bg-sky-600"
               title="Ver info de {{ hechizo.nombre }}">
              i
            </a>
            
            <div class="absolute top-[40%] left-2.5 w-7 h-7 bg-zinc-800 border-2 border-zinc-600 rounded-md flex items-center justify-center font-black text-xs text-white shadow-md">
              10
            </div>
            
            <div class="absolute bottom-0 left-0 w-full bg-black/40 border-t border-white/20 px-2 py-1 flex items-center justify-between text-white font-black text-sm">
              <span>{{ hechizo.espacio }}</span>
              <div class="w-5 h-5 bg-zinc-700 rounded-full flex items-center justify-center border border-white/50 overflow-hidden">
                <img src="/images/decorativas/" alt="Icono del hechizo">
              </div>
            </div>
          </div>
        {% else %}
          <p class="col-span-full text-sm font-bold text-gray-500 italic">No hay hechizos actualmente.</p>
        {% endfor %}
      </div>
    </section>


    <!-- BOTONES DE GUARDAR Y CANCELAR -->
    <div class="flex justify-end gap-4 border-t-2 border-coc-wood-light pt-6">
      <a href="/formaciones" class="coc-btn coc-btn-gold">
        <span>Cancelar</span>
      </a>
      <button type="submit" class="coc-btn coc-btn-green cursor-pointer">
        <span>Guardar Formación</span>
      </button>
    </div>

  </form>
</div>
{% endblock %}