{% extends "base.njk" %}
{% block titulo %}Cuartel de Tropas{% endblock %}
{% block contenido %}
<div class="max-w-6xl mx-auto py-8 px-4">
  <h1 class="text-3xl font-black text-white mb-6 uppercase tracking-wider">Tropas Disponibles</h1>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
    {% for tropa in tropas %}
      {% include "partials/card_tropa.njk" %}
    {% else %}
      <p class="text-white italic">No hay tropas registradas en el cuartel.</p>
    {% endfor %}
  </div>
</div>
{% endblock %}