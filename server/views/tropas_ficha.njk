{% extends "base.njk" %}

{% block titulo %}Ficha de {{ tropa.nombre }} - Clash of Clans{% endblock %}

{% block contenido %}
<div class="bg-coc-cesped py-12 px-4 min-h-screen animate-coc-fade-in">
  <div class="max-w-3xl mx-auto">
    
    <div class="mb-6">
      <a href="javascript:history.back()" class="inline-flex items-center gap-2 coc-btn-gold font-black px-4 py-2 border-2 border-coc-wood-light rounded-xl shadow-md hover:scale-105 transition-all text-xs uppercase tracking-wider">
        Volver atrás
      </a>
    </div>

    <div class="coc-container">
      
      <h3 class="block text-2xl coc-title-gold pb-3 text-center md:text-left">
        {{ tropa.nombre }} de Nivel {{ tropa.nivelMaximo }}
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="bg-black/30 p-4 rounded-xl border-2 border-coc-wood-dark flex items-center justify-center aspect-square max-h-75 mx-auto md:max-h-none w-full">
          <img src="{{ tropa.imagenGrande }}" alt="{{ tropa.nombre }}" class="w-full h-full object-contain select-none">
        </div>

        <div class="space-y-3 font-bold text-sm">
          <div class="bg-coc-wood-ultra-dark p-3 rounded-xl border flex justify-between items-center shadow-md">
            <span class="text-coc-text-muted uppercase tracking-wider text-xs">Vida:</span>
            <span class="text-white font-black text-lg">{{ tropa.vida }}</span>
          </div>

          <div class="bg-coc-wood-ultra-dark p-3 rounded-xl border flex justify-between items-center shadow-md">
            <span class="text-coc-text-muted uppercase tracking-wider text-xs">Daño por segundo:</span>
            <span class="text-white font-black text-lg">{{ tropa.dano }}</span>
          </div>

          <div class="bg-coc-wood-ultra-dark p-3 rounded-xl border flex justify-between items-center shadow-md">
            <span class="text-coc-text-muted uppercase tracking-wider text-xs">Objetivos:</span>
            <span class="text-white font-black uppercase text-base tracking-wide">{{ tropa.objetivo }}</span>
          </div>

          <div class="bg-coc-wood-ultra-dark p-3 rounded-xl border flex justify-between items-center shadow-md">
            <span class="text-coc-text-muted uppercase tracking-wider text-xs">Espacio en viviendas:</span>
            <div class="flex items-center gap-2">
              <span class="text-coc-text-gold font-black text-lg">{{ tropa.espacio }}</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
{% endblock %}