{% extends "base.njk" %}

{% block titulo %}Editar Formación - Clash of Clans{% endblock %}

{% block contenido %}
<div class="bg-coc-cesped py-8 px-4 animate-coc-fade-in">
  <div class="max-w-6xl mx-auto space-y-8">
    
    <!-- HEADER CON CONTADORES -->
    <header class="coc-container flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <h1 class="text-3xl font-black text-transparent coc-title-gold">
          Modificar Formación
        </h1>
        <p class="text-sm text-coc-text-muted font-bold mt-1">Modifica la composición de tu formación de combate.</p>
      </div>
      <div class="flex gap-4">
        <div class="bg-black/40 border-2 border-coc-wood-light px-4 py-2 rounded-xl text-center">
          <span class="block text-xs uppercase text-coc-text-muted font-bold tracking-widest">Capacidad Tropas</span>
          <span id="txt-contador-tropas" class="text-xl font-black text-coc-text-gold">0 / 352</span>
        </div>
        <div class="bg-black/40 border-2 border-coc-wood-light px-4 py-2 rounded-xl text-center">
          <span class="block text-xs uppercase text-coc-text-muted font-bold tracking-widest">Capacidad Hechizos</span>
          <span id="txt-contador-hechizos" class="text-xl font-black text-white">0 / 11</span>
        </div>
      </div>
    </header>

    <!-- FORMULARIO DE EDICIÓN -->
    <form action="/formaciones/{{ formacion.id }}" method="post" class="space-y-8">
        <input type="hidden" name="_method" value="PUT">
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 coc-container">
        <div class="md:col-span-1">
          <label for="nombre" class="block text-sm font-black text-coc-text-muted uppercase tracking-wider mb-2">Nombre de la Formación</label>
          <input type="text" id="nombre" name="nombre" value="{{ formacion.nombre }}" required
                 class="w-full px-4 py-2.5 bg-amber-50 border-2 border-coc-wood-light rounded-lg font-bold text-coc-wood-dark focus:outline-hidden focus:border-coc-gold">
        </div>
        <div class="md:col-span-2">
          <label for="descripcion" class="block text-sm font-black text-coc-text-muted uppercase tracking-wider mb-2">Estrategia / Descripción</label>
          <input type="text" id="descripcion" name="descripcion" value="{{ formacion.descripcion }}" required
                 class="w-full px-4 py-2.5 bg-amber-50 border-2 border-coc-wood-light rounded-lg font-bold text-coc-wood-dark focus:outline-hidden focus:border-coc-gold">
        </div>
      </div>

        <!-- TITULO Y DESCRIPCIÓN -->
      <section class="coc-container">
        <h2 class="text-xl font-black text-coc-text-light uppercase tracking-wider mb-4 flex items-center gap-2">
           Composición Actual de la Formación
        </h2>
        <div id="contenedor-composicion" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 bg-black/30 p-4 rounded-xl border-2 border-coc-wood-light">
          </div>
      </section>

        <!-- SECCIÓN DE TROPAS DISPONIBLES -->
      <section class="coc-container">
        <h2 class="text-xl font-black text-coc-text-light uppercase tracking-wider mb-4 flex items-center gap-2">
          Seleccionar Tropas Disponibles
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 bg-black/20 p-4 rounded-xl border-2 border-coc-wood-light">
          {% set esFormulario = true %}
          {% for tropa in tropas %}
            {% include "partials/card_tropa.njk" %}
          {% else %}
            <p class="col-span-full text-sm font-bold text-coc-text-muted italic text-center">No hay tropas actualmente.</p>
          {% endfor %}
        </div>
      </section>

        <!-- SECCIÓN DE HECHIZOS DISPONIBLES -->
      <section class="coc-container">
        <h2 class="text-xl font-black text-coc-text-light uppercase tracking-wider mb-4 flex items-center gap-2">
          Seleccionar Hechizos Disponibles
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 bg-black/20 p-4 rounded-xl border-2 border-coc-wood-light">
          {% set esFormulario = true %}
          {% for hechizo in hechizos %}
            {% include "partials/card_hechizo.njk" %}
          {% else %}
            <p class="col-span-full text-sm font-bold text-coc-text-muted italic text-center">No hay hechizos actualmente.</p>
          {% endfor %}
        </div>
      </section>

        <!-- BOTONES DE GUARDAR Y CANCELAR -->
      <div class="flex justify-end gap-4 coc-container">
        <a href="/formaciones" class="coc-btn coc-btn-gold">
          <span>Cancelar</span>
        </a>
        <button type="submit" class="coc-btn coc-btn-green cursor-pointer">
          <span>Guardar Cambios</span>
        </button>
      </div>

    </form>
  </div>
</div>

<script>
  window.esFormulario = true;
  
  // Arrays del estado de la formación
  var listaTropas = [];
  var listaHechizos = [];

  // Limites de espacio
  var MAX_TROPAS = 352;
  var MAX_HECHIZOS = 11;
  var espacioTropasActual = 0;
  var espacioHechizosActual = 0;

  // Cargo las tropas de la formación actual en los arrays para poder editarlas
  {% for item in formacion.tropas %}
    {% if item.tropa %}
      listaTropas.push({
        id: '{{ item.tropa.id }}',
        nombre: '{{ item.tropa.nombre }}',
        imagen: '{{ item.tropa.imagenIcono }}',
        espacio: {{ item.tropa.espacio }},
        nivelMaximo: {{ item.tropa.nivelMaximo }},
        cantidad: {{ item.cantidad }}
      });
      espacioTropasActual += ({{ item.tropa.espacio }} * {{ item.cantidad }});
    {% endif %}
  {% endfor %}

// Cargo los hechizos de la formación actual en los arrays para poder editarlos
  {% for item in formacion.hechizos %}
    {% if item.hechizo %}
      listaHechizos.push({
        id: '{{ item.hechizo.id }}',
        nombre: '{{ item.hechizo.nombre }}',
        imagen: '{{ item.hechizo.imagenIcono }}',
        espacio: {{ item.hechizo.espacio }},
        nivelMaximo: {{ item.hechizo.nivelMaximo }},
        cantidad: {{ item.cantidad }}
      });
      espacioHechizosActual += ({{ item.hechizo.espacio }} * {{ item.cantidad }});
    {% endif %}
  {% endfor %}

  // Ejecuto la función para mostrar correctamente las tropas y hechizos ya cargados al editar, y actualizar los contadores
  actualizarInterfaz();

  function agregar(tipo, id, nombre, imagen, espacio, nivelMaximo) {
    if (tipo === 'tropa') {
      if (espacioTropasActual + espacio > MAX_TROPAS) return;
      var encontrado = false;
      for (var i = 0; i < listaTropas.length; i++) {
        if (listaTropas[i].id === id) {
          listaTropas[i].cantidad += 1;
          encontrado = true;
        }
      }
      if (!encontrado) {
        listaTropas.push({ id: id, nombre: nombre, imagen: imagen, espacio: espacio, nivelMaximo: nivelMaximo, cantidad: 1 });
      }
      espacioTropasActual += espacio;
    } else if (tipo === 'hechizo') {
      if (espacioHechizosActual + espacio > MAX_HECHIZOS) return;
      var encontrado = false;
      for (var i = 0; i < listaHechizos.length; i++) {
        if (listaHechizos[i].id === id) {
          listaHechizos[i].cantidad += 1;
          encontrado = true;
        }
      }
      if (!encontrado) {
        listaHechizos.push({ id: id, nombre: nombre, imagen: imagen, espacio: espacio, nivelMaximo: nivelMaximo, cantidad: 1 });
      }
      espacioHechizosActual += espacio;
    }
    actualizarInterfaz();
  }

  function borrar(tipo, id, espacio) {
    if (tipo === 'tropa') {
      for (var i = 0; i < listaTropas.length; i++) {
        if (listaTropas[i].id === id) {
          listaTropas[i].cantidad -= 1;
          espacioTropasActual -= espacio;
          if (listaTropas[i].cantidad === 0) {
            listaTropas.splice(i, 1);
          }
          break;
        }
      }
    } else if (tipo === 'hechizo') {
      for (var i = 0; i < listaHechizos.length; i++) {
        if (listaHechizos[i].id === id) {
          listaHechizos[i].cantidad -= 1;
          espacioHechizosActual -= espacio;
          if (listaHechizos[i].cantidad === 0) {
            listaHechizos.splice(i, 1);
          }
          break;
        }
      }
    }
    actualizarInterfaz();
  }

  function verificarEspacios() {
    {% for tropa in tropas %}
      var cardTropa = document.getElementById("tropa-{{ tropa.id }}");
      if (cardTropa) {
        var espacioDeTropa = {{ tropa.espacio }};
        if (espacioTropasActual + espacioDeTropa > MAX_TROPAS) {
          cardTropa.classList.add("grayscale", "opacity-50", "pointer-events-none");
          cardTropa.classList.remove("hover:scale-105", "hover:border-white");
        } else {
          cardTropa.classList.remove("grayscale", "opacity-50", "pointer-events-none");
          cardTropa.classList.add("hover:scale-105", "hover:border-white");
        }
      }
    {% endfor %}

    {% for hechizo in hechizos %}
      var cardHechizo = document.getElementById("hechizo-{{ hechizo.id }}");
      if (cardHechizo) {
        var espacioEsteHechizo = {{ hechizo.espacio }};
        if (espacioHechizosActual + espacioEsteHechizo > MAX_HECHIZOS) {
          cardHechizo.classList.add("grayscale", "opacity-50", "pointer-events-none");
          cardHechizo.classList.remove("hover:scale-105", "hover:border-white");
        } else {
          cardHechizo.classList.remove("grayscale", "opacity-50", "pointer-events-none");
          cardHechizo.classList.add("hover:scale-105", "hover:border-white");
        }
      }
    {% endfor %}
  }

  function actualizarInterfaz() {
    var contenedor = document.getElementById('contenedor-composicion');
    contenedor.innerHTML = "";

    if (listaTropas.length === 0 && listaHechizos.length === 0) {
      contenedor.innerHTML = '<p id="mensaje-vacio" class="col-span-full text-sm font-bold text-coc-text-muted italic text-center">No hay ninguna tropa o hechizo seleccionado...</p>';
    }

    for (var i = 0; i < listaTropas.length; i++) {
      var t = listaTropas[i];
      var htmlCard = `
        <div class="relative aspect-square bg-sky-200 border-[3px] border-coc-wood-dark rounded-xl shadow-md">
          <img src="${t.imagen}" alt="${t.nombre}" class="w-full h-full object-cover select-none rounded-lg">
          <button type="button" onclick="borrar('tropa', '${t.id}', ${t.espacio})" 
                  class="absolute -top-1 -right-1 w-6 h-6 bg-red-600 border border-black rounded-full flex items-center justify-center font-black text-white shadow-md hover:bg-red-700 cursor-pointer text-xs">
            -
          </button>
          ${t.cantidad > 1 ? `<div class="absolute top-1.5 left-1.5 bg-black/80 px-1.5 py-0.5 rounded-md font-black text-xs text-coc-text-gold border border-coc-wood-light shadow-md">x${t.cantidad}</div>` : ''}
          <div class="absolute top-[40%] left-1.5 w-7 h-7 bg-linear-to-b from-coc-gold to-coc-gold-dark border-2 border-coc-wood-light rounded-md flex items-center justify-center font-black text-xs text-coc-wood-dark shadow-md">
            ${t.nivelMaximo}
          </div>
          <div class="absolute bottom-0 left-0 w-full bg-black/60 border-t border-white/10 px-2 py-0.5 flex items-center justify-between text-white font-black text-xs rounded-b-lg">
            <span>${t.espacio * t.cantidad}</span>
            <img src="/img/decorativas/generic-stickman.png" alt="Espacio" class="w-6 h-6">
          </div>
          <input type="hidden" name="tropas[${i}][tropa]" value="${t.id}">
          <input type="hidden" name="tropas[${i}][cantidad]" value="${t.cantidad}">
        </div>
      `;
      contenedor.innerHTML += htmlCard;
    }

    for (var j = 0; j < listaHechizos.length; j++) {
      var h = listaHechizos[j];
      var htmlCard = `
        <div class="relative aspect-square bg-emerald-200 border-[3px] border-coc-wood-dark rounded-xl shadow-md">
          <img src="${h.imagen}" alt="${h.nombre}" class="w-full h-full object-cover select-none rounded-lg">
          <button type="button" onclick="borrar('hechizo', '${h.id}', ${h.espacio})" 
                  class="absolute -top-1 -right-1 w-6 h-6 bg-red-600 border border-black rounded-full flex items-center justify-center font-black text-white shadow-md hover:bg-red-700 cursor-pointer text-xs">
            -
          </button>
          ${h.cantidad > 1 ? `<div class="absolute top-1.5 left-1.5 bg-black/80 px-1.5 py-0.5 rounded-md font-black text-xs text-coc-text-gold border border-coc-wood-light shadow-md">x${h.cantidad}</div>` : ''}
          <div class="absolute top-[40%] left-1.5 w-7 h-7 bg-linear-to-b from-coc-gold to-coc-gold-dark border-2 border-coc-wood-light rounded-md flex items-center justify-center font-black text-xs text-coc-wood-dark shadow-md">
            ${h.nivelMaximo}
          </div>
          <div class="absolute bottom-0 left-0 w-full bg-black/60 border-t border-white/10 px-2 py-0.5 flex items-center justify-between text-white font-black text-xs rounded-b-lg">
            <span>${h.espacio * h.cantidad}</span>
            <img src="/img/decorativas/elixir-spells.png" alt="Espacio" class="w-6 h-6">
          </div>
          <input type="hidden" name="hechizos[${j}][hechizo]" value="${h.id}">
          <input type="hidden" name="hechizos[${j}][cantidad]" value="${h.cantidad}">
        </div>
      `;
      contenedor.innerHTML += htmlCard;
    }

    document.getElementById('txt-contador-tropas').innerText = espacioTropasActual + " / " + MAX_TROPAS;
    document.getElementById('txt-contador-hechizos').innerText = espacioHechizosActual + " / " + MAX_HECHIZOS;

    verificarEspacios();
  }
</script>
{% endblock %}